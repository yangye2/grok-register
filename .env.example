TZ=Asia/Shanghai

# Console login (leave password empty to disable auth)
GROK_REGISTER_AUTH_USER=admin
GROK_REGISTER_AUTH_PASSWORD=
GROK_REGISTER_AUTH_SECRET=
GROK_REGISTER_AUTH_SESSION_HOURS=168

GROK_STACK_CONSOLE_PORT=18600
GROK_STACK_CONSOLE_BIND=127.0.0.1
GROK_REGISTER_IMAGE=ghcr.io/yangye2/grok-register:latest
GROK_REGISTER_DEFAULT_RUN_COUNT=50
GROK_REGISTER_DEFAULT_PROXY=socks5://warp:1080
GROK_REGISTER_DEFAULT_BROWSER_PROXY=socks5://warp:1080

GROK_REGISTER_DEFAULT_TEMP_MAIL_API_BASE=
GROK_REGISTER_DEFAULT_TEMP_MAIL_ADMIN_PASSWORD=
GROK_REGISTER_DEFAULT_TEMP_MAIL_DOMAIN=
GROK_REGISTER_DEFAULT_TEMP_MAIL_SITE_PASSWORD=

GROK_REGISTER_DEFAULT_CPA_EXPORT_ENABLED=true
GROK_REGISTER_DEFAULT_CPA_AUTH_DIR=/workspace/cpa_auths
GROK_REGISTER_DEFAULT_CPA_PROXY=
GROK_REGISTER_DEFAULT_CPA_HEADLESS=false
GROK_REGISTER_DEFAULT_CPA_MINT_TIMEOUT_SEC=300
CPA_ALLOW_HEADLESS=false

CPA_CLOUD_UPLOAD_ENABLED=false
CPA_CLOUD_API_BASE=
CPA_CLOUD_MANAGEMENT_KEY=
CPA_CLOUD_UPLOAD_TIMEOUT=30
CPA_CLOUD_UPLOAD_RETRIES=3
